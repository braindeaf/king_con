      %img{:height => "28", :src => "https://bulma.io/images/bulma-logo.png", :width => "112"}/
  .navbar-menu
    .navbar-start
      %a.navbar-item
        Home
      %a.navbar-item
        About
    .navbar-end
      .navbar-item
        .buttons
