            = link_to destroy_user_session_path, class: 'button is-primary', data: { 'turbo-method': 'delete' } do
              %strong Logout
          - else
            = link_to new_user_registration_path, class: 'button is-primary' do
              %strong Sign Up
            = link_to new_user_session_path, class: 'button is-light' do
              %strong Log In
